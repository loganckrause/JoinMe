# ============================================================================
# JoinMe Backend Configuration
# ============================================================================
# Copy this file to .env and update values for your environment

# DATABASE CONFIGURATION
# ============================================================================
# If connecting to local MySQL:
DATABASE_URL=mysql+pymysql://joinme:joinme_password@localhost:3306/joinme


# SECURITY CONFIGURATION
# ============================================================================
# IMPORTANT: Generate a strong secret key in production
# Python: from secrets import token_urlsafe; print(token_urlsafe(32))
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# JWT Algorithm (don't change unless you have a reason)
ALGORITHM=HS256

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30


# API CONFIGURATION
# ============================================================================
# Host for the API server
# Use 0.0.0.0 for Docker (accessible from outside container)
# Use localhost for local development
API_HOST=0.0.0.0

# Port for the API server
API_PORT=8000

# Google Cloud service account email for images
GCS_SERVICE_ACCOUNT_EMAIL=email

# STORAGE CONFIGURATION
# ============================================================================
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

GOOGLE_MAPS_API_KEY=