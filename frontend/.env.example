# ============================================================================
# JoinMe Frontend Configuration
# ============================================================================
# Copy this file to .env.local and update values for your environment

# API CONFIGURATION
# ============================================================================
# Backend API URL
# Local development (web/simulator): http://localhost:8000
# Local development (physical phone): http://YOUR_MACHINE_IP:8000
# Production: https://api.yourdomain.com

EXPO_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# ============================================================================

# LOCAL DEVELOPMENT (simulator/web):
# EXPO_PUBLIC_API_URL=http://localhost:8000

# LOCAL DEVELOPMENT (physical phone):
# Get your machine IP with: ifconfig | grep inet
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000

# PRODUCTION:
# EXPO_PUBLIC_API_URL=https://api.joinme.com
