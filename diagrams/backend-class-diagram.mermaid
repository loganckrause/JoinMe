classDiagram
    class DatabaseManager {
        +engine
        +SessionLocal
        +get_db()
    }

    class BaseEntity {
        <<Interface>>
        +int id
        +datetime created_at
    }

    class User {
        +String email
        +String password_hash
        +float safety_score
        +update_safety_score(new_rating)
    }

    class Event {
        +int creator_id
        +int category_id
        +datetime event_date
        +Decimal lat
        +Decimal long
    }

    class UserCreate {
        <<Pydantic>>
        +String email
        +String password
    }

    class UserRead {
        <<Pydantic>>
        +int id
        +String email
    }

    class EventCreate {
        <<Pydantic>>
        +int category_id
        +datetime event_date
    }

    class Token {
        <<Pydantic>>
        +String access_token
        +String token_type
    }

    class UserRouter {
        +APIRouter router
        +signup(user: UserCreate)
        +login(form_data: OAuth2PasswordRequestForm)
        +get_me(token: String)
    }

    class EventRouter {
        +APIRouter router
        +get_feed(user_id: int)
        +create_event(event: EventCreate)
    }

    class RecommendationService {
        +LightFM model
        +prepare_data(swipes, attendance, prefs)
        +get_event_stack(user_id) List~int~
    }

    class SafetyService {
        +verify_user_rating(rater_id, ratee_id)
        +calculate_rep_decay(ratings)
        +process_user_report(report_data)
    }

    class AuthService {
        +verify_password(plain, hashed)
        +create_access_token(data)
    }

    class ScoringService {
        +process_event_rating(user_id, event_id, score)
        +calculate_event_popularity(event_id)
    }

    BaseEntity <|-- User
    BaseEntity <|-- Event
    BaseEntity <|-- Swipe
    BaseEntity <|-- Attendance
    BaseEntity <|-- User_Rating
    BaseEntity <|-- Event_Rating

    %% Entity Interactions
    User "1" --> "*" Event : creates
    User "1" --> "*" Swipe : makes
    Event "1" --> "*" Swipe : receives
    User "1" --> "*" Attendance : attends
    Event "1" --> "*" Attendance : has
    User "1" --> "*" User_Rating : gives
    User "1" --> "*" User_Rating : receives
    User "1" --> "*" Event_Rating : gives
    Event "1" --> "*" Event_Rating : receives

    UserRouter ..> UserCreate : validates
    UserRouter ..> UserRead : returns
    UserRouter ..> AuthService : uses
    UserRouter ..> User : manages
    EventRouter ..> EventCreate : validates
    EventRouter ..> RecommendationService : calls
    EventRouter ..> Event : returns

    DatabaseManager ..> BaseEntity

    ScoringService --> Event_Rating
    ScoringService ..> Event
    
    RecommendationService ..> ScoringService
    RecommendationService ..> Swipe
    
    SafetyService --> User_Rating
    SafetyService ..> User

    AuthService ..> Token : creates